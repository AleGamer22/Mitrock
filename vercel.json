{
  "version": 2,
  "builds": [
    {
      "src": "chatbot.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/ia(?:/.*)?$",
      "dest": "chatbot.py"
    },
    {
      "src": "^/styles\\.css$",
      "dest": "/public/styles.css"
    },
    {
      "src": "^/(.*)$",
      "dest": "/public/index.html"
    }
  ]
}
